# ============================================================
# Diffbot Navigation - clang-format 配置
# 基于 ROS2 代码风格，适配 Google 风格基线
# ============================================================
BasedOnStyle: Google
Language: Cpp

# 缩进
IndentWidth: 2
TabWidth: 2
UseTab: Never

# 行宽
ColumnLimit: 100

# 大括号
BreakBeforeBraces: Custom
BraceWrapping:
  AfterClass: false
  AfterControlStatement: Never
  AfterEnum: false
  AfterFunction: false
  AfterNamespace: false
  AfterStruct: false
  AfterUnion: false
  BeforeCatch: false
  BeforeElse: false
  IndentBraces: false

# 空格
SpaceAfterCStyleCast: false
SpaceBeforeAssignmentOperators: true
SpaceBeforeParens: ControlStatements

# 指针对齐
DerivePointerAlignment: false
PointerAlignment: Left

# 包含排序
IncludeBlocks: Preserve
SortIncludes: Never

# 访问修饰符偏移
AccessModifierOffset: -2

# 注释
ReflowComments: false

# 空白行
MaxEmptyLinesToKeep: 1
