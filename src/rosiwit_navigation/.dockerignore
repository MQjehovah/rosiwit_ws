# ============================================================
# .dockerignore - Exclude files from Docker build context
# ============================================================

# Build artifacts
build/
install/
log/
.ccache/

# Version control
.git/
.gitignore
.gitmodules

# IDE / Editor
.vscode/
.idea/
*.swp
*.swo
*~

# OS files
.DS_Store
Thumbs.db

# Docker
Dockerfile
docker-compose.yml
.dockerignore
docker-entrypoint.sh

# CI/CD
.github/
.gitlab-ci.yml

# Documentation (not needed in image)
docs/

# Test results
test_results/
coverage/

# Python artifacts
__pycache__/
*.pyc
*.egg-info/
