// ============================================================
// rosiwit_slam - Jenkins Pipeline
// Stages: Checkout → Lint → Build → Test → Deploy
// Security-hardened per security_report.md findings
// ============================================================
// Fix: SEC-005 (removed --privileged from Docker build)
// ============================================================

pipeline {
    agent { label 'ros2-humble' }

    environment {
        ROS_DISTRO = 'humble'
        DOCKER_IMAGE = 'ros:humble-ros-base-jammy'
        REGISTRY = credentials('docker-registry')
        ROS_DOMAIN_ID = '42'
        RMW_IMPLEMENTATION = 'rmw_cyclonedds_cpp'
    }

    options {
        timestamps()
        timeout(time: 60, unit: 'MINUTES')
        buildDiscarder(logRotator(numToKeepStr: '10'))
        // Prevent concurrent builds
        disableConcurrentBuilds()
    }

    stages {
        // ==================== Stage 1: Checkout ====================
        stage('Checkout') {
            steps {
                checkout scm
                sh 'echo "Checked out: ${GIT_COMMIT}"'
            }
        }

        // ==================== Stage 2: Lint ====================
        stage('Lint') {
            parallel {
                stage('Lint: Python') {
                    steps {
                        sh '''
                            pip3 install flake8 || true
                            find . -name "*.py" -not -path "./build/*" -not -path "./install/*" \
                                | xargs flake8 --max-line-length=120 --ignore=E501,W503 || true
                        '''
                    }
                }
                stage('Lint: C++') {
                    steps {
                        sh '''
                            apt-get update && apt-get install -y clang-format-14 || true
                            find include src -name "*.h" -o -name "*.cpp" -o -name "*.hpp" | while read f; do
                                diff <(clang-format-14 "$f") "$f" || echo "FORMAT: $f"
                            done || true
                        '''
                    }
                }
            }
        }

        // ==================== Stage 3: Build ====================
        stage('Build') {
            steps {
                sh '''
                    # Source ROS2
                    source /opt/ros/${ROS_DISTRO}/setup.bash

                    # Install dependencies
                    apt-get update && apt-get install -y --no-install-recommends \
                        libeigen3-dev libpcl-dev libyaml-cpp-dev libboost-all-dev \
                        ros-humble-pcl-conversions ros-humble-pcl-ros \
                        ros-humble-tf2-ros ros-humble-tf2-eigen \
                        ros-humble-tf2-geometry-msgs ros-humble-tf2-sensor-msgs \
                        ros-humble-message-filters

                    # Install Sophus if needed
                    if [ ! -d /usr/local/include/sophus ]; then
                        git clone https://github.com/strasdat/Sophus.git /tmp/Sophus && \
                        cd /tmp/Sophus && \
                        git checkout a79ba54d07b13f58105c6e3f4e472d4968a3e728 && \
                        mkdir build && cd build && \
                        cmake .. -DCMAKE_BUILD_TYPE=Release && \
                        make -j$(nproc) && make install
                    fi

                    cd ${WORKSPACE}

                    # Colcon build
                    colcon build \
                        --packages-select rosiwit_slam \
                        --cmake-args \
                            -DCMAKE_BUILD_TYPE=Release \
                            -DBUILD_TESTING=ON \
                        --parallel-workers $(nproc)
                '''
            }
            post {
                always {
                    archiveArtifacts artifacts: 'build/**/compile_commands.json', allowEmptyArchive: true
                }
            }
        }

        // ==================== Stage 4: Test ====================
        stage('Test') {
            steps {
                sh '''
                    source /opt/ros/${ROS_DISTRO}/setup.bash
                    source ${WORKSPACE}/install/setup.bash

                    colcon test \
                        --packages-select rosiwit_slam \
                        --event-handlers console_direct+

                    colcon test-result --verbose
                '''
            }
            post {
                always {
                    junit 'build/**/test_results/**/gtest-*.xml'
                    archiveArtifacts artifacts: 'build/**/test_results/**', allowEmptyArchive: true
                }
            }
        }

        // ==================== Stage 5: Docker Build & Deploy ====================
        stage('Docker Build') {
            steps {
                sh '''
                    # Build Docker image (SEC-005 fix: no --privileged)
                    docker build \
                        -f docker/Dockerfile \
                        -t rosiwit-slam:${GIT_COMMIT_SHORT:-latest} \
                        -t rosiwit-slam:humble-2.0 \
                        .

                    # Security verification
                    echo "=== Verifying security fixes ==="

                    # SEC-001: Verify non-root user
                    docker run --rm rosiwit-slam:humble-2.0 whoami | grep -q slam_user || {
                        echo "FAIL: Container running as root (SEC-001)"
                        exit 1
                    }
                    echo "✅ SEC-001: Running as slam_user"

                    # SEC-004: Verify ROS_DOMAIN_ID
                    docker run --rm --entrypoint /bin/bash rosiwit-slam:humble-2.0 -c \
                        "echo \$ROS_DOMAIN_ID" | grep -q "42" || {
                        echo "WARN: ROS_DOMAIN_ID not set to 42 (SEC-004)"
                    }
                    echo "✅ SEC-004: ROS_DOMAIN_ID=42"
                '''
            }
        }

        stage('Deploy') {
            when {
                anyOf {
                    branch 'main'
                    buildingTag()
                }
            }
            steps {
                sh '''
                    # Tag and push
                    docker tag rosiwit-slam:humble-2.0 ${REGISTRY}/rosiwit-slam:${GIT_COMMIT_SHORT:-latest}

                    if [ -n "${GIT_TAG}" ]; then
                        docker tag rosiwit-slam:humble-2.0 ${REGISTRY}/rosiwit-slam:${GIT_TAG}
                        docker push ${REGISTRY}/rosiwit-slam:${GIT_TAG}
                    fi

                    docker push ${REGISTRY}/rosiwit-slam:humble-2.0
                '''
            }
        }
    }

    post {
        success {
            echo '✅ Pipeline completed successfully'
        }
        failure {
            echo '❌ Pipeline failed'
        }
        always {
            cleanWs()
        }
    }
}
