# SetInitialPose.srv
# 设置初始位姿服务

# 请求
geometry_msgs/Pose initial_pose  # 初始位姿
float64 covariance_position_x    # X方向位置协方差
float64 covariance_position_y    # Y方向位置协方差
float64 covariance_position_z    # Z方向位置协方差
float64 covariance_orientation   # 姿态协方差

---
# 响应
bool success                  # 设置是否成功
string message               # 状态消息