# GlobalLocalize.srv
# 触发全局定位服务

# 请求
bool use_initial_hint        # 是否使用初始位姿提示
geometry_msgs/Pose initial_pose  # 可选的初始位姿估计

---
# 响应
bool success                  # 定位是否成功
geometry_msgs/Pose estimated_pose  # 估计的位姿
float64 fitness_score         # 配准得分
float64 confidence            # 置信度
float64 time_elapsed         # 耗时（秒）
string message               # 状态消息