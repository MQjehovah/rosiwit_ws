# ============================================================
# rosiwit_app - Environment Variables Template
# Copy this file to .env and customize as needed:
#   cp .env.example .env
# ============================================================

# --- ROS2 Configuration ---
# DDS domain ID (all nodes must share the same ID)
ROS_DOMAIN_ID=42

# DDS middleware implementation
# Options: rmw_cyclonedds_cpp, rmw_fastrtps_cpp
RMW_IMPLEMENTATION=rmw_cyclonedds_cpp

# Log level: DEBUG, INFO, WARN, ERROR, FATAL
ROS_LOG_LEVEL=INFO

# --- Map Storage ---
# Directory for SLAM map files (PCD, PGM, YAML) and last position JSON
MAP_PATH=/tmp/rosiwit_sim_map

# --- GUI / Display ---
# X11 display for RViz/Gazebo (leave empty for headless)
DISPLAY=:0

# --- Docker Build ---
# Docker image tag
DOCKER_TAG=1.0.0

# Docker registry (for CI/CD push)
# DOCKER_REGISTRY=ghcr.io/your-org
